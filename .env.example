PORT=3000
HOST=0.0.0.0
UPSTREAM_URL=https://api.openai.com

# Attention filter settings (Unified SetFit Engine)
ENABLE_ATTENTION_FILTER=true
HF_MODEL_NAME=naranor/SetFit-ModernBERT-WAMP-V1
FILTER_MODEL_DIR=./model
FILTER_THRESHOLD_MULTIPLIER=1.0

# Optimal Multipliers for ModernBERT
FILTER_NEEDLE_MULT=0.98
FILTER_REASONING_MULT=0.74
FILTER_SUMMARY_MULT=1.00

# Optimal Algorithms for ModernBERT
FILTER_NEEDLE_ALGO=cls_max
FILTER_REASONING_ALGO=max_max
FILTER_SUMMARY_ALGO=max_max

# ModernBERT supports up to 8192.
FILTER_MAX_TOKENS=2048