PORT=3000
HOST=0.0.0.0
UPSTREAM_URL=https://api.openai.com

# Attention filter settings (Unified SetFit Engine)
ENABLE_ATTENTION_FILTER=true
HF_MODEL_NAME=naranor/SetFit-Multilingual-ONNX-Router-V1
FILTER_MODEL_DIR=./model
FILTER_THRESHOLD_MULTIPLIER=1.0

# Optimal Multipliers for SetFit (cls_max algorithm)
# Research Step 6 Safe Mode: 100% Recall
FILTER_NEEDLE_MULT=0.99
FILTER_REASONING_MULT=0.95
FILTER_SUMMARY_MULT=0.99

# Algorithm selection (mean_max, cls_max, mean_mean, max_max)
FILTER_NEEDLE_ALGO=cls_max
FILTER_REASONING_ALGO=cls_max
FILTER_SUMMARY_ALGO=cls_max

FILTER_MAX_TOKENS=512